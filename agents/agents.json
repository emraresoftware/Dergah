{
  "version": 1,
  "repoRoot": "./",
  "baseBranch": "main",
  "worktreeRoot": "./agents/worktrees",
  "agents": [
    {
      "id": "orchestrator",
      "branch": "agent/orchestrator",
      "path": "agents/worktrees/orchestrator",
      "focus": ["planning", "dependencies", "merge-gate", "release-check", "repo-hygiene"]
    },
    {
      "id": "core",
      "branch": "agent/core",
      "path": "agents/worktrees/core",
      "focus": ["dervis-core", "dergah-orkestrator", "niyet-akisi", "is-kurallari"]
    },
    {
      "id": "panel",
      "branch": "agent/panel",
      "path": "agents/worktrees/panel",
      "focus": ["dervis-panel", "widget", "ui-akisi", "panel-state"]
    },
    {
      "id": "integration",
      "branch": "agent/integration",
      "path": "agents/worktrees/integration",
      "focus": ["github-relay", "network-bootstrap", "node-sync", "api-security"]
    },
    {
      "id": "quality",
      "branch": "agent/quality",
      "path": "agents/worktrees/quality",
      "focus": ["syntax-check", "smoke-tests", "health-check", "regression-gate"]
    },
    {
      "id": "ops",
      "branch": "agent/ops",
      "path": "agents/worktrees/ops",
      "focus": ["scripts", "startup", "runtime", "log-operations"]
    },
    {
      "id": "yonetici",
      "branch": "agent/yonetici",
      "path": "agents/workspaces/yonetici",
      "role": "manager",
      "focus": ["sprint-planlama", "gorev-dagilimi", "merge-kapisi", "kalite-onay", "handoff-koordinasyon"],
      "description": "Yönetici ajan — sprint açar/kapar, görevleri dağıtır, merge kararı verir"
    },
    {
      "id": "api-dev",
      "branch": "agent/api-dev",
      "path": "agents/workspaces/api-dev",
      "role": "developer",
      "focus": ["rest-endpoints", "route-tasarim", "controller", "api-dokumantasyon"],
      "description": "API geliştiricisi — REST endpoint tasarımı ve implementasyonu"
    },
    {
      "id": "sunucu-dev",
      "branch": "agent/sunucu-dev",
      "path": "agents/workspaces/sunucu-dev",
      "role": "developer",
      "focus": ["express-server", "middleware", "config", "hata-yonetimi"],
      "description": "Sunucu geliştiricisi — Express kurulumu, middleware zinciri, config"
    },
    {
      "id": "veri-dev",
      "branch": "agent/veri-dev",
      "path": "agents/workspaces/veri-dev",
      "role": "developer",
      "focus": ["veri-modelleri", "storage-katmani", "crud-ops", "veri-validasyon"],
      "description": "Veri geliştiricisi — model tasarımı, JSON/DB storage katmanı"
    },
    {
      "id": "guvenlik-dev",
      "branch": "agent/guvenlik-dev",
      "path": "agents/workspaces/guvenlik-dev",
      "role": "developer",
      "focus": ["input-validasyon", "auth-middleware", "rate-limit", "guvenlik-header"],
      "description": "Güvenlik geliştiricisi — validasyon, auth, güvenlik önlemleri"
    },
    {
      "id": "test-dev",
      "branch": "agent/test-dev",
      "path": "agents/workspaces/test-dev",
      "role": "developer",
      "focus": ["unit-test", "integration-test", "smoke-test", "test-coverage"],
      "description": "Test geliştiricisi — tüm katmanlar için test yazımı ve CI"
    }
  ]
}

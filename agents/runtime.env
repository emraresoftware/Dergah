# Ajan çalışma modu: worktree | copy | direct
# worktree : Her ajan kendi git worktree'sine yazar (git geçmişi önemliyse)
# copy     : Her ajan rsync ile kopyalanan klasöre yazar (git yoksa)
# direct   : Tüm ajanlar tek canonical repo'ya doğrudan yazar (en basit)
MODE=direct

# Canonical repo'nun mutlak yolu
REPO_DIR=/Users/emre/Dergah

# (Opsiyonel) worktree modu için base branch
BASE_BRANCH=main

# Dergah - OpenClaw + Exo backend example
# Copy these variables into your shell profile or export before launching scripts.

# Provider: ollama | openai_compat
export DERGAH_LLM_PROVIDER="openai_compat"

# Main chat model exposed by Exo API
export DERGAH_MODEL_NAME="qwen2.5:32b"

# Exo OpenAI-compatible base URL (M5 Pro host)
export DERGAH_OPENAI_API_BASE="http://100.x.x.x:52415/v1"

# Optional if your Exo gateway enforces token auth
export DERGAH_OPENAI_API_KEY=""

# Timeout for model HTTP calls (seconds)
export DERGAH_LLM_TIMEOUT="120"

# Optional vision model (still Ollama-based in dervis_core visual path)
export DERGAH_VISION_MODEL_NAME="llama3.2-vision"
